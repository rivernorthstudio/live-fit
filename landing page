<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Apex — Corporate Fitness</title>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --white: #ffffff; --near-white: #f5f5f7; --light-gray: #e8e8ed;
  --mid-gray: #6e6e73; --dark: #1d1d1f; --black: #000000;
  --blue: #0071e3; --blue-hover: #0077ed;
}
html { scroll-behavior: smooth; }
body {
  font-family: -apple-system,"SF Pro Display","SF Pro Text","Helvetica Neue",sans-serif;
  background: var(--white); color: var(--dark);
  overflow-x: hidden; -webkit-font-smoothing: antialiased;
}
 
/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 999;
  height: 48px;
  background: rgba(255,255,255,0.82);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1px solid rgba(0,0,0,0.1);
  display: flex; align-items: center; justify-content: space-between; padding: 0 22px;
}
.nav-logo { color: var(--dark); text-decoration: none; display: flex; align-items: center; }
.nav-logo svg { width: 18px; height: 22px; fill: var(--dark); }
.nav-links { display: flex; }
.nav-links a { font-size: 12px; color: var(--dark); text-decoration: none; padding: 0 10px; opacity: 0.8; transition: opacity 0.2s; }
.nav-links a:hover { opacity: 1; }
.nav-actions { display: flex; gap: 16px; }
.nav-actions a { font-size: 12px; color: var(--dark); text-decoration: none; opacity: 0.8; }
.nav-actions a:hover { opacity: 1; }
 
/* ── HERO ── */
.hero {
  min-height: 100vh; position: relative; overflow: hidden;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding-top: 48px; background: #000;
}
 
/* 8-cell photo mosaic */
.hero-mosaic {
  position: absolute; inset: 0;
  display: grid; grid-template-columns: repeat(4,1fr); grid-template-rows: repeat(2,1fr); gap: 3px;
}
.hm-cell { overflow: hidden; }
.hm-cell img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  filter: brightness(0.3) saturate(0.55);
  animation: hzoom 20s ease-in-out infinite alternate;
}
.hm-cell:nth-child(1) img { animation-delay: 0s; }
.hm-cell:nth-child(2) img { animation-delay: -4s; animation-direction: alternate-reverse; }
.hm-cell:nth-child(3) img { animation-delay: -8s; }
.hm-cell:nth-child(4) img { animation-delay: -2s; animation-direction: alternate-reverse; }
.hm-cell:nth-child(5) img { animation-delay: -6s; animation-direction: alternate-reverse; }
.hm-cell:nth-child(6) img { animation-delay: -10s; }
.hm-cell:nth-child(7) img { animation-delay: -3s; animation-direction: alternate-reverse; }
.hm-cell:nth-child(8) img { animation-delay: -7s; }
@keyframes hzoom { from { transform: scale(1.1); } to { transform: scale(1.0); } }
 
.hero-overlay {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 50% 52%, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.82) 75%),
    linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.0) 20%, rgba(0,0,0,0.0) 70%, rgba(0,0,0,0.65) 100%);
}
.hero-glow {
  position: absolute; bottom: 8%; left: 50%; transform: translateX(-50%);
  width: 560px; height: 220px; border-radius: 50%;
  background: radial-gradient(ellipse, rgba(0,113,227,0.28) 0%, transparent 70%);
  pointer-events: none;
}
 
.hero-content {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; align-items: center; padding: 0 24px;
}
.hero-eyebrow {
  font-size: 19px; font-weight: 600; color: #f5f5f7; letter-spacing: 0.01em; margin-bottom: 10px;
  opacity: 0; animation: fadeDown 0.9s 0.4s cubic-bezier(0.22,1,0.36,1) forwards;
}
.hero-title {
  font-size: clamp(58px, 9vw, 112px); font-weight: 700; line-height: 1.02;
  letter-spacing: -0.018em; color: #fff; margin-bottom: 22px;
  opacity: 0; animation: fadeDown 0.9s 0.55s cubic-bezier(0.22,1,0.36,1) forwards;
}
.hero-sub {
  font-size: clamp(17px, 2.2vw, 23px); font-weight: 400; color: rgba(245,245,247,0.74);
  max-width: 560px; line-height: 1.46; letter-spacing: 0.012em; margin-bottom: 36px;
  opacity: 0; animation: fadeDown 0.9s 0.7s cubic-bezier(0.22,1,0.36,1) forwards;
}
.hero-ctas {
  display: flex; gap: 20px; align-items: center;
  opacity: 0; animation: fadeDown 0.9s 0.85s cubic-bezier(0.22,1,0.36,1) forwards;
}
.btn-blue {
  font-size: 17px; font-weight: 400; color: #fff; background: var(--blue);
  border: none; border-radius: 980px; padding: 12px 28px; cursor: pointer;
  text-decoration: none; transition: background 0.2s, transform 0.15s;
}
.btn-blue:hover { background: var(--blue-hover); transform: translateY(-1px); }
.btn-ghost-white {
  font-size: 17px; color: rgba(255,255,255,0.88); text-decoration: none;
  display: inline-flex; align-items: center; gap: 3px; transition: gap 0.2s;
}
.btn-ghost-white::after { content: '›'; font-size: 22px; line-height: 1; }
.btn-ghost-white:hover { gap: 8px; }
 
/* scroll line */
.hero-scroll {
  position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
  z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 7px;
  opacity: 0; animation: fadeIn 1s 1.7s forwards;
}
.scroll-line { width: 1px; height: 38px; background: rgba(255,255,255,0.25); position: relative; overflow: hidden; }
.scroll-line::after {
  content: ''; position: absolute; top: -100%; left: 0; right: 0; height: 100%;
  background: rgba(255,255,255,0.7); animation: scrollDrop 2.2s ease-in-out 1.9s infinite;
}
@keyframes scrollDrop { 0% { top:-100%; } 100% { top:220%; } }
.scroll-label { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
 
/* ── LOGO BAR ── */
.logo-bar { padding: 52px 40px; text-align: center; background: var(--white); border-bottom: 1px solid var(--light-gray); }
.logo-bar p { font-size: 13px; color: var(--mid-gray); margin-bottom: 30px; }
.logo-row { display: flex; justify-content: center; align-items: center; gap: 52px; flex-wrap: wrap; }
.logo-item { font-size: 19px; font-weight: 600; color: #c7c7cc; letter-spacing: -0.02em; cursor: default; transition: color 0.25s; }
.logo-item:hover { color: #86868b; }
 
/* ── PHOTO TILES ── */
.tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding: 8px; background: var(--near-white); }
 
.tile {
  border-radius: 18px; overflow: hidden; position: relative;
  min-height: 500px; display: flex; flex-direction: column; justify-content: flex-end;
}
.tile-full { grid-column: span 2; min-height: 580px; }
 
.tile-photo { position: absolute; inset: 0; }
.tile-photo img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.85s cubic-bezier(0.22,1,0.36,1);
}
.tile:hover .tile-photo img { transform: scale(1.05); }
 
.tile-overlay { position: absolute; inset: 0; }
.ov-dark-btm { background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.38) 45%, rgba(0,0,0,0.04) 100%); }
.ov-blue     { background: linear-gradient(140deg, rgba(0,40,110,0.88) 0%, rgba(0,113,227,0.6) 100%); }
.ov-dark-full{ background: rgba(0,0,0,0.52); }
 
.tile-body { position: relative; z-index: 2; padding: 40px 44px; }
.tile-tag { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.tile-h2 { font-size: clamp(28px, 3.8vw, 52px); font-weight: 700; letter-spacing: -0.022em; line-height: 1.06; margin-bottom: 12px; }
.tile-p { font-size: 17px; line-height: 1.5; margin-bottom: 22px; max-width: 480px; }
.tile-link {
  font-size: 17px; color: #fff; text-decoration: none;
  display: inline-flex; align-items: center; gap: 3px; transition: gap 0.2s;
}
.tile-link::after { content: '›'; font-size: 21px; line-height: 1; }
.tile-link:hover { gap: 8px; }
.tw { color: #fff; } .tw70 { color: rgba(255,255,255,0.76); }
.td { color: var(--dark); } .tg { color: var(--mid-gray); } .tb { color: var(--blue); }
 
/* Glassmorphism stat badges */
.stat-badge {
  position: absolute; z-index: 3;
  background: rgba(10,10,10,0.52);
  backdrop-filter: blur(18px) saturate(160%);
  -webkit-backdrop-filter: blur(18px) saturate(160%);
  border: 1px solid rgba(255,255,255,0.13);
  border-radius: 16px; padding: 14px 20px; min-width: 118px; text-align: center;
}
.sb-num { font-size: 30px; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
.sb-lbl { font-size: 11px; color: rgba(255,255,255,0.55); margin-top: 4px; letter-spacing: 0.02em; }
 
/* pill buttons */
.pill-blue { font-size: 15px; font-weight: 500; background: var(--blue); color: #fff; padding: 10px 22px; border-radius: 980px; text-decoration: none; transition: background 0.2s; }
.pill-blue:hover { background: var(--blue-hover); }
.pill-out-blue { font-size: 15px; font-weight: 500; color: var(--blue); border: 1px solid var(--blue); padding: 10px 22px; border-radius: 980px; text-decoration: none; transition: all 0.2s; }
.pill-out-blue:hover { background: var(--blue); color: #fff; }
 
/* Split coaching tile */
.tile-split { flex-direction: row; }
.tile-split-left { flex: 1; min-width: 300px; background: var(--near-white); display: flex; flex-direction: column; justify-content: center; padding: 64px 52px; position: relative; z-index: 2; }
.tile-split-right { flex: 1.3; position: relative; overflow: hidden; min-height: 520px; }
.tile-split-right img { width: 100%; height: 100%; object-fit: cover; object-position: center 15%; display: block; transition: transform 0.85s cubic-bezier(0.22,1,0.36,1); }
.tile-split-right::after { content:''; position:absolute; inset:0; background: linear-gradient(to right, rgba(245,245,247,0.45) 0%, transparent 25%); }
.tile:hover .tile-split-right img { transform: scale(1.05); }
 
/* ── PHOTO STRIP ── */
.photo-strip {
  display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.6fr;
  height: 360px; gap: 6px; background: var(--black);
}
.ps { position: relative; overflow: hidden; cursor: default; }
.ps img { width:100%; height:100%; object-fit:cover; display:block; filter:brightness(0.72) saturate(0.82); transition: transform 0.75s cubic-bezier(0.22,1,0.36,1), filter 0.5s; }
.ps:hover img { transform: scale(1.06); filter: brightness(0.9) saturate(1.05); }
.ps-cap { position:absolute; bottom:18px; left:18px; color:rgba(255,255,255,0.84); font-size:12px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; text-shadow:0 1px 8px rgba(0,0,0,0.55); }
 
/* ── FEATURES ── */
.features { background: var(--black); color: #fff; padding: 110px 40px; text-align: center; }
.features-tag { font-size: 17px; font-weight: 600; color: #30d158; margin-bottom: 8px; }
.features-h2 { font-size: clamp(36px,5vw,64px); font-weight: 700; letter-spacing: -0.022em; line-height: 1.07; margin-bottom: 18px; }
.features-sub { font-size: 19px; color: rgba(245,245,247,0.68); max-width: 520px; margin: 0 auto 56px; line-height: 1.5; }
.feat-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; max-width: 1100px; margin: 0 auto; border-radius: 18px; overflow: hidden; }
.feat-card { background: #1c1c1e; padding: 44px 34px; text-align: left; transition: background 0.3s; }
.feat-card:hover { background: #2c2c2e; }
.feat-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 22px; }
.ic-b{background:rgba(0,113,227,0.18);color:#2997ff} .ic-g{background:rgba(48,209,88,0.18);color:#30d158}
.ic-o{background:rgba(255,159,10,0.18);color:#ff9f0a} .ic-p{background:rgba(255,55,95,0.18);color:#ff375f}
.ic-t{background:rgba(52,170,220,0.18);color:#34aadc} .ic-v{background:rgba(191,90,242,0.18);color:#bf5af2}
.feat-title { font-size: 19px; font-weight: 600; margin-bottom: 9px; }
.feat-desc { font-size: 14px; color: rgba(245,245,247,0.56); line-height: 1.65; }
 
/* ── STATS ── */
.stats { display:grid; grid-template-columns:repeat(4,1fr); background:var(--near-white); position:relative; }
.stats::before { content:''; position:absolute; inset:0; background:var(--light-gray); z-index:0; }
.stat { background:var(--near-white); padding:60px 20px; text-align:center; position:relative; z-index:1; }
.stat-num { font-size:56px; font-weight:700; letter-spacing:-0.03em; line-height:1; margin-bottom:8px; }
.stat-lbl { font-size:14px; color:var(--mid-gray); line-height:1.55; max-width:180px; margin:0 auto; }
 
/* ── TESTIMONIAL ── */
.testi-wrap { position:relative; overflow:hidden; }
.testi-bg { position:absolute; inset:0; }
.testi-bg img { width:100%; height:100%; object-fit:cover; object-position:center 30%; filter:brightness(0.08) saturate(0.3); display:block; }
.testi-fade { position:absolute; inset:0; background:rgba(255,255,255,0.93); }
.testi-inner { position:relative; z-index:1; padding:110px 40px; text-align:center; }
.testi-quote { font-size:clamp(22px,2.8vw,38px); font-weight:400; letter-spacing:-0.014em; line-height:1.3; max-width:800px; margin:0 auto 40px; }
.testi-quote strong { font-weight:600; }
.testi-attr { font-size:15px; color:var(--mid-gray); display:flex; align-items:center; justify-content:center; gap:12px; }
.testi-av { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#0071e3,#34aadc); display:flex; align-items:center; justify-content:center; color:#fff; font-size:13px; font-weight:600; }
 
/* ── PRICING ── */
.pricing { background:var(--near-white); padding:100px 40px; text-align:center; }
.pricing-tag { font-size:17px; font-weight:600; color:var(--blue); margin-bottom:8px; }
.pricing-h2 { font-size:clamp(34px,5vw,58px); font-weight:700; letter-spacing:-0.022em; margin-bottom:14px; }
.pricing-sub { font-size:19px; color:var(--mid-gray); margin-bottom:56px; line-height:1.42; }
.pricing-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; max-width:1000px; margin:0 auto; }
.p-card { background:var(--white); border-radius:20px; padding:40px 32px; text-align:left; border:1px solid transparent; transition:border-color 0.3s, box-shadow 0.3s; position:relative; }
.p-card:hover { border-color:rgba(0,113,227,0.25); box-shadow:0 8px 40px rgba(0,113,227,0.07); }
.p-card.p-featured { border-color:var(--blue); box-shadow:0 4px 32px rgba(0,113,227,0.14); }
.p-badge { position:absolute; top:-1px; left:50%; transform:translateX(-50%); background:var(--blue); color:#fff; font-size:12px; font-weight:600; padding:4px 16px; border-radius:0 0 10px 10px; }
.p-tier { font-size:21px; font-weight:600; margin-bottom:4px; }
.p-price { font-size:52px; font-weight:700; letter-spacing:-0.03em; line-height:1; margin-bottom:4px; }
.p-price sup { font-size:24px; font-weight:500; vertical-align:super; }
.p-period { font-size:14px; color:var(--mid-gray); margin-bottom:26px; }
.p-div { height:1px; background:var(--light-gray); margin-bottom:22px; }
.p-feats { list-style:none; margin-bottom:30px; display:flex; flex-direction:column; gap:11px; }
.p-feats li { font-size:14px; display:flex; align-items:flex-start; gap:9px; line-height:1.45; }
.pcheck { color:var(--blue); flex-shrink:0; margin-top:1px; }
.p-cta { display:block; width:100%; font-size:16px; font-weight:400; padding:12px; border-radius:980px; text-align:center; text-decoration:none; cursor:pointer; font-family:inherit; border:none; transition:all 0.2s; }
.p-prim { background:var(--blue); color:#fff; } .p-prim:hover { background:var(--blue-hover); }
.p-out { background:transparent; color:var(--blue); border:1px solid var(--blue); } .p-out:hover { background:var(--blue); color:#fff; }
 
/* ── CTA BAND ── */
.cta-band { position:relative; overflow:hidden; background:var(--black); color:#fff; padding:130px 40px; text-align:center; }
.cta-photo { position:absolute; inset:0; }
.cta-photo img { width:100%; height:100%; object-fit:cover; object-position:center 40%; filter:brightness(0.18) saturate(0.5); display:block; }
.cta-glow { position:absolute; inset:0; background:radial-gradient(ellipse 70% 80% at 50% 100%, rgba(0,113,227,0.32), transparent 65%); }
.cta-inner { position:relative; z-index:1; }
.cta-h2 { font-size:clamp(36px,5vw,66px); font-weight:700; letter-spacing:-0.022em; line-height:1.05; margin-bottom:16px; }
.cta-sub { font-size:21px; color:rgba(245,245,247,0.72); margin-bottom:40px; line-height:1.42; }
.cta-form { display:flex; gap:12px; justify-content:center; max-width:480px; margin:0 auto; }
.cta-email { flex:1; padding:14px 20px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.22); border-radius:980px; color:#fff; font-size:17px; font-family:inherit; outline:none; transition:border-color 0.2s,background 0.2s; }
.cta-email::placeholder { color:rgba(255,255,255,0.38); }
.cta-email:focus { border-color:rgba(255,255,255,0.5); background:rgba(255,255,255,0.15); }
.cta-submit { padding:14px 28px; border-radius:980px; background:#fff; color:var(--black); font-size:17px; font-weight:500; border:none; cursor:pointer; font-family:inherit; transition:background 0.2s; white-space:nowrap; }
.cta-submit:hover { background:var(--near-white); }
.cta-note { font-size:12px; color:rgba(245,245,247,0.38); margin-top:16px; }
 
/* ── FOOTER ── */
footer { background:#f5f5f7; border-top:1px solid #d2d2d7; padding:20px 22px; }
.fc { font-size:12px; color:var(--mid-gray); margin-bottom:8px; line-height:1.6; }
.fl { display:flex; flex-wrap:wrap; gap:8px 24px; }
.fl a { font-size:12px; color:var(--mid-gray); text-decoration:none; transition:color 0.2s; }
.fl a:hover { color:var(--blue); }
.fd { height:1px; background:#d2d2d7; margin:14px 0; }
.fb { display:flex; justify-content:space-between; flex-wrap:wrap; gap:8px; }
.fcountry { font-size:12px; color:var(--mid-gray); }
 
/* ── ANIMATIONS ── */
@keyframes fadeDown { from { opacity:0; transform:translateY(-14px); } to { opacity:1; transform:translateY(0); } }
@keyframes fadeIn   { from { opacity:0; } to { opacity:1; } }
.reveal { opacity:0; transform:translateY(28px); transition:opacity 0.75s cubic-bezier(0.22,1,0.36,1), transform 0.75s cubic-bezier(0.22,1,0.36,1); }
.reveal.in { opacity:1; transform:none; }
.d1{transition-delay:0.1s} .d2{transition-delay:0.2s} .d3{transition-delay:0.3s} .d4{transition-delay:0.4s}
 
/* Activity rings */
.ring-wrap { position:relative; }
.aring { position:absolute; border-radius:50%; }
.aring svg { display:block; }
@keyframes rspin { from { transform:translate(-50%,-50%) rotate(0deg); } to { transform:translate(-50%,-50%) rotate(360deg); } }
</style>
</head>
<body>
 
<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">
    <svg viewBox="0 0 18 22" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 0C9 0 5 2.5 5 7c0 3 2 5.5 4 6.5C11 12.5 13 10 13 7 13 2.5 9 0 9 0Z" opacity="0.9"/>
      <rect x="7.5" y="11" width="3" height="11" rx="1.5"/>
    </svg>
  </a>
