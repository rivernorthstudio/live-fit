    <a href="#">Platform</a><a href="#">Services</a><a href="#">Enterprise</a>
    <a href="#">Analytics</a><a href="#">Pricing</a><a href="#">Support</a>
  </div>
  <div class="nav-actions"><a href="#">Sign In</a></div>
</nav>
 
<!-- ══ HERO — 8-photo mosaic background ══ -->
<section class="hero">
  <div class="hero-mosaic">
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1549060279-7e168fcee0c2?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1540497077202-7c8a3999166f?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=700&q=80&fit=crop" alt="" loading="eager"></div>
    <div class="hm-cell"><img src="https://images.unsplash.com/photo-1574680178050-55c6a6a96e0a?w=700&q=80&fit=crop" alt="" loading="eager"></div>
  </div>
  <div class="hero-overlay"></div>
